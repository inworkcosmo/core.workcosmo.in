# Example environment variables for the auth server
# Either set GOOGLE_APPLICATION_CREDENTIALS to a service account JSON file path
# or set FIREBASE_SERVICE_ACCOUNT as the full JSON string for the service account.

# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# Or as raw JSON (use with caution):
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

PORT=4000
